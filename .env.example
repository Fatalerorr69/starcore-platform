# STARCORE Platform - environment configuration template
# Copy to .env and fill in real values. .env is gitignored.

STARCORE_API_HOST=0.0.0.0
STARCORE_API_PORT=8000
STARCORE_DEBUG=false

STARCORE_POSTGRES_URL=postgresql://starcore:starcore@localhost:5432/starcore
STARCORE_REDIS_URL=redis://localhost:6379
STARCORE_NATS_URL=nats://localhost:4222

# Proxmox API token (Datacenter -> Permissions -> API Tokens)
STARCORE_PROXMOX_HOST=
STARCORE_PROXMOX_USER=
STARCORE_PROXMOX_TOKEN_NAME=
STARCORE_PROXMOX_TOKEN_VALUE=
STARCORE_PROXMOX_VERIFY_SSL=true

# Shared secret required in the X-API-Key header for protected endpoints.
# API is closed by default (503) until this is set.
STARCORE_API_KEY=change-me-to-a-random-secret

# Requests per minute allowed per client IP across the whole API (except
# /health, which is never rate-limited). Set to 0 to disable.
STARCORE_RATE_LIMIT_PER_MINUTE=60

# AI-assisted blueprint generation (starcore ai generate / POST /ai/generate-blueprint)
STARCORE_ANTHROPIC_API_KEY=
STARCORE_ANTHROPIC_MODEL=claude-sonnet-5
